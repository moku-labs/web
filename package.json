{
  "name": "@moku-labs/web",
  "version": "0.3.1",
  "description": "Content static-site generator + SPA web framework for TypeScript, built on @moku-labs/core.",
  "author": "Oleksandr Kucherenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moku-labs/web.git"
  },
  "bugs": {
    "url": "https://github.com/moku-labs/web/issues"
  },
  "homepage": "https://github.com/moku-labs/web#readme",
  "keywords": [
    "web",
    "framework",
    "static-site-generator",
    "ssg",
    "spa",
    "preact",
    "typescript",
    "moku"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@moku-labs/core": "0.1.0-alpha.6",
    "@resvg/resvg-js": "2.6.2",
    "@shikijs/rehype": "3.22.0",
    "feed": "5.2.0",
    "gray-matter": "4.0.3",
    "hast-util-sanitize": "5.0.2",
    "p-limit": "6.2.0",
    "preact": "10.29.2",
    "preact-render-to-string": "6.6.0",
    "reading-time": "1.5.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "satori": "0.19.1",
    "shiki": "3.22.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "1.3.14",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "happy-dom": "20.9.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "publint": "0.3.21",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18"
  },
  "scripts": {
    "build": "tsdown",
    "validate": "publint",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage"
  }
}
