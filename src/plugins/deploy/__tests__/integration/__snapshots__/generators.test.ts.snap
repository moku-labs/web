// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`deploy generators integration > snapshots deploy.yml with SHA-pinned actions 1`] = `
"# .github/workflows/deploy.yml — generated by \`app.deploy.init({ ci: true })\`.
# Actions are SHA-pinned (not floating tags) for supply-chain hygiene.

name: Deploy

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: oven-sh/setup-bun@4bc047ad259df6fc24a6c9b0f9a0cb08cf17fbe5 # v2.0.1
      - run: bun install --frozen-lockfile
      - run: bun run build
      - uses: cloudflare/wrangler-action@f84a562284fc78278ff9052435d9526f9c718361 # v4.0.0
        with:
          apiToken: \${{ secrets.CLOUDFLARE_API_TOKEN }}
          accountId: \${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
          wranglerVersion: "4.34.0"
          command: pages deploy dist --project-name my-site
"
`;

exports[`deploy generators integration > snapshots wrangler.jsonc from slug + outDir + compatibilityDate 1`] = `
"{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-site",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2024-01-01"
}
"
`;
